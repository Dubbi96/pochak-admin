{
  "expo": {
    "name": "POCHAK",
    "slug": "pochak",
    "version": "1.0.0",
    "scheme": "pochak",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00C700"
    },
    "ios": {
      "supportsTablet": true,
      "associatedDomains": ["applinks:pochak.co.kr"],
      "bundleIdentifier": "com.pochak.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00C700"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "pochak.co.kr",
              "pathPrefix": "/content"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "package": "com.pochak.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-screen-orientation"
    ]
  }
}

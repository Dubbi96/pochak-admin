# Cloud Orchestrator connection
CLOUD_API_URL=http://localhost:4000/api/v1
RUNNER_API_TOKEN=ktr_your_runner_token_here

# Redis (same Redis as cloud orchestrator uses)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Runner identity
TENANT_ID=your-tenant-uuid
RUNNER_ID=your-runner-uuid
RUNNER_PLATFORMS=web

# Katab CLI paths
KATAB_CLI_PATH=../Katab_Stack/packages/recorder/dist/cli.js
SCENARIO_DIR=./scenarios
REPORT_DIR=./reports

# Local API port
LOCAL_API_PORT=5001

# Queue prefix (must match cloud)
QUEUE_PREFIX=katab

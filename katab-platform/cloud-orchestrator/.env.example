# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=katab
DB_PASSWORD=katab_secret
DB_DATABASE=katab_orchestrator

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRATION=24h

# Server
PORT=4000
NODE_ENV=development

# S3 (Scenario/Report Storage)
AWS_S3_BUCKET=katab-scenarios
AWS_S3_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Runner Communication
RUNNER_QUEUE_PREFIX=katab

# ============================================================
# Pochak OTT Platform - Only track pochak/ directory
# Everything else in ~/Dubbi is separate projects
# ============================================================

# Ignore everything at root level
/*

# Except pochak project
!/pochak/
!/pochak/**

# Except this gitignore
!/.gitignore

# Standard ignores within pochak
pochak/**/node_modules/
pochak/**/.next/
pochak/**/dist/
pochak/**/build/
pochak/**/.gradle/
pochak/**/*.jar
pochak/**/.DS_Store
pochak/**/.env
pochak/**/.env.local
